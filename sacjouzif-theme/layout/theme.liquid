<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">

  {{ content_for_header }}

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600;900&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>

  <!-- Custom Cursor -->
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <!-- Loader -->
  <div id="loader">
    <div class="logo-load">{{ shop.name | upcase }}</div>
    <div class="load-bar"></div>
  </div>

  <!-- Header -->
  {% section 'header' %}

  <!-- Cart Drawer -->
  {% section 'cart-drawer' %}

  <!-- Main Content -->
  <main id="main-content">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {% section 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
